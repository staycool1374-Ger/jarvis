:name: Jarvis RTOS - AArch64
:description: Boots Jarvis RTOS on ARM Cortex-A53.

$name?="jarvis-aarch64"
mach create $name

machine LoadPlatformDescription @tools/renode/jarvis-aarch64.repl

$kernel?=@build/kernel-debug.elf

macro reset
"""
    sysbus LoadELF $kernel
    cpu0 SetAvailableExceptionLevels true false
    cpu0 PC 0x40080000
    cpu0 CPSR 0x3C5
"""
runMacro $reset
start