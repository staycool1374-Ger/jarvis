{"nodes": [{"id": "readme_jarvisrtos", "label": "Jarvis RTOS", "file_type": "document", "source_file": "readme.html", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "readme_irqguard", "label": "IrqGuard RAII Interrupt Guard", "file_type": "concept", "source_file": "readme.html", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Eliminates check-then-act races by using RAII scope guard for cli()/sti(). The guard cannot be forgotten, duplicated, or left dangling, unlike manual taskENTER_CRITICAL/taskEXIT_CRITICAL in FreeRTOS."}, {"id": "readme_raii_synchronization", "label": "RAII-First Kernel Synchronisation", "file_type": "rationale", "source_file": "readme.html", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Every critical section enforced by scoped guard, not by convention. Pattern extends to mutexes (with priority inheritance), semaphores, event groups, and scheduler dispatch. Makes it structurally impossible to leak a critical section."}, {"id": "readme_o1_scheduler", "label": "O(1) Deterministic Scheduler", "file_type": "concept", "source_file": "readme.html", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "readme_microkernel_transition", "label": "Microkernel Paradigm Shift", "file_type": "rationale", "source_file": "readme.html", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Deliberate architectural migration from monolithic to capability-based microkernel planned over Phases 3-8. Current monolithic ring-0 service layer structured as isolated subsystems with clean interface boundaries, making extraction to servers a matter of wrapping, not rewriting."}, {"id": "readme_test_framework", "label": "Kernel Test Framework", "file_type": "concept", "source_file": "readme.html", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "readme_competitive_comparison", "label": "FreeRTOS vs Jarvis RTOS Comparison", "file_type": "document", "source_file": "readme.html", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "readme_phase2_kernelcore", "label": "Phase 2: Kernel Core & Shell", "file_type": "concept", "source_file": "readme.html", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "readme_phase3_systemservices", "label": "Phase 3: System Services & Hardware", "file_type": "concept", "source_file": "readme.html", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "readme_phase5_hardrealtime", "label": "Phase 5: Hard Real-Time", "file_type": "concept", "source_file": "readme.html", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "readme_phase8_microkernel", "label": "Phase 8: Microkernel Transition", "file_type": "concept", "source_file": "readme.html", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "readme_call_for_contributions", "label": "Call for Contributions", "file_type": "document", "source_file": "readme.html", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}], "edges": [{"source": "readme_jarvisrtos", "target": "readme_irqguard", "relation": "conceptually_related_to", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "readme.html", "source_location": null, "weight": 1.0}, {"source": "readme_jarvisrtos", "target": "readme_raii_synchronization", "relation": "conceptually_related_to", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "readme.htm