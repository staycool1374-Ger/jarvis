{"nodes": [{"id": "docs_privilege_audit_audit", "label": "Kernel Subsystem Privilege Audit v0.2.9", "file_type": "document", "source_file": "docs/privilege_audit.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "docs_privilege_audit_vfsd", "label": "VFS Daemon (vfsd)", "file_type": "concept", "source_file": "docs/privilege_audit.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "VFS Core, procfs, and initrd_fs are candidates for /sbin/vfsd userspace server because VNode path resolution, mount tables, and fd table management are pure computation with no hardware access."}, {"id": "docs_privilege_audit_iocd", "label": "IO Daemon (iocd)", "file_type": "concept", "source_file": "docs/privilege_audit.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Keyboard, Serial, Timer/RTC, and devfs device I/O are candidates for /sbin/iocd userspace server. Requires IRQ forwarding mechanism and I/O port access via TSS I/O bitmap."}, {"id": "docs_privilege_audit_capability_transition", "label": "Capability-based Microkernel Transition Plan", "file_type": "rationale", "source_file": "docs/privilege_audit.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Recommended migration order: IPC Latency Benchmark -> Unprivileged Shell -> Capability-based Hardware Access -> Userspace VFS Server -> Userspace Driver Server. Requires IRQ and I/O port mechanisms for driver isolation."}, {"id": "docs_privilege_audit_gdt", "label": "GDT", "file_type": "concept", "source_file": "docs/privilege_audit.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Ring-0-only structure because lgdt instruction requires ring 0. Cannot move to userspace."}, {"id": "docs_privilege_audit_idt", "label": "IDT", "file_type": "concept", "source_file": "docs/privilege_audit.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Ring-0-only because lidt instruction requires ring 0. Exception/interrupt handling cannot run in userspace."}, {"id": "docs_privilege_audit_pmm", "label": "PMM", "file_type": "concept", "source_file": "docs/privilege_audit.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Must stay ring 0 because physical memory management requires privileged access to EFI memory map and physical page manipulation."}, {"id": "docs_privilege_audit_vmm", "label": "VMM", "file_type": "concept", "source_file": "docs/privilege_audit.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Must stay ring 0 because page table management (CR3, INVLPG, HHDM mapping) is ring-0-only."}, {"id": "docs_privilege_audit_vfs", "label": "VFS Core", "file_type": "concept", "source_file": "docs/privilege_audit.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Can move to ring 3 because VNode path resolution, mount table, and fd table management are pure computation with no hardware access. Candidate for /sbin/vfsd."}, {"id": "docs_privilege_audit_elfloader", "label": "ELF Loader", "file_type": "concept", "source_file": "docs/privilege_audit.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Cannot move to ring 3 because ELF loading maps pages into target process address space via VMM, which requires ring 0."}, {"id": "docs_privilege_audit_scheduler", "label": "Scheduler", "file_type": "concept", "source_file": "docs/privilege_audit.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Cannot move to ring 3 because context switching (CR3, RSP0 via TSS) is inherently ring 0."}, {"id": "docs_privilege_audit_ipc", "label": "IPC", "file_type": "concept", "source_file": "docs/privilege_audit.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Data structures could be shared, but IPC::send/recv functions that interact with scheduler (block_sender, wake_sender) must stay in ring 0 because they manipulate task states."}, {"id": "docs_privilege_audit_shell", "label": "Kernel Shell", "file_type": "concept", "source_file": "docs/privilege_audit.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Can move to ring 3 -- userspace shell already exists and runs via syscalls. Highest priority migration candidate."}], "edges": [{"source": "docs_privilege_audit_audit", "target": "readme_jarvisrtos", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/privilege_audit.md", "source_location": null, "weight": 1.0}, {"source": "docs_privilege_audit_audit", "target": "docs_privilege_audit_vfsd", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/privilege_audit.md", "source_location": null, "weight": 1.0}, {"source": "docs_privilege_audit_audit", "target": "docs_privilege_audit_iocd", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/privilege_audit.md", "source_location": null, "weight": 1.0}, {"source": "docs_privilege_audit_audit", "target": "docs_privilege_audit_capability_transition", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/privilege_audit.md", "source_location": null, "weight": 1.0}, {"source": "docs_privilege_audit_audit", "target": "docs_privilege_audit_gdt", "relation": "references", "co