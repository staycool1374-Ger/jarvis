{"nodes": [{"id": "readme_md_jarvis_rtos", "label": "Jarvis RTOS", "file_type": "concept", "source_file": "README.md", "source_location": "1-191", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "readme_md_irqguard", "label": "IrqGuard RAII Interrupt Guard", "file_type": "concept", "source_file": "README.md", "source_location": "44-106", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "readme_md_microkernel_transition", "label": "Capability-Based Microkernel Transition", "file_type": "rationale", "source_file": "README.md", "source_location": "67-73", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Deliberate architectural migration from monolithic ring-0 service layer to capability-based microkernel with externalised VFS/drivers/block I/O as Ring 3 servers communicating via IPC capabilities. Current monolithic code is structured as isolated subsystems with clean interface boundaries to make extraction a wrapping exercise, not a rewrite."}, {"id": "readme_md_cplusplus20_freestanding", "label": "Freestanding C++20 Kernel", "file_type": "rationale", "source_file": "README.md", "source_location": "33-41", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "No libc, no libstdc++, no runtime \u2014 zero-overhead object-oriented kernel design, compile-time type safety, deterministic execution. C++20 Concepts for compile-time validation, constexpr/consteval for static scheduling parameters, RAII for all kernel resources, noexcept by default with -fno-exceptions."}, {"id": "readme_md_rate_monotonic_scheduler", "label": "Rate-Monotonic Scheduler (256 Priority Levels)", "file_type": "concept", "source_file": "README.md", "source_location": "220-224", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "readme_md_resource_tracker_principle", "label": "ResourceTracker Leak Detection Principle", "file_type": "rationale", "source_file": "README.md", "source_location": "181-183", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Architecture over features \u2014 a new driver does not ship without a test, a ResourceTracker entry, and a documented failure mode."}], "edges": [{"source": "readme_md_jarvis_rtos", "target": "license_txt_gplv3", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "README.md", "source_location": "191", "weight": 1.0}, {"source": "readme_md_jarvis_rtos", "target": "readme_md_irqguard", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "README.md", "source_location": "44-106", "weight": 1.0}, {"source": "readme_md_jarvis_rtos", "target": "readme_md_microkernel_transition", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "README.md", "source_location": "67-73", "weight": 1.0}, {"source": "readme_md_jarvis_rtos", "target": "readme_md_cplusplus20_freestanding", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "README.md", "source_location": "33-41", "weight": 1.0}, {"source": "readme_md_jarvis_rtos", "target": "readme_md_rate_monotonic_scheduler", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "README.md", "source_location": "220-224", "weight": 1.0}, {"source": "readme_md_jarvis_rtos", "target": "roadmap_md_phase_4_hard_real_time", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "README.md", "source_location": "109-119", "weight": 1.0}, {"source": "readme_md_jarvis_rtos", "target": "jarvis_cla_md_contributor_agreement", "relation": "cites", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "README.md", "source_location": "170-185", "weight": 1.0}, {"source": "readme_md_microkernel_transition", "target": "roadmap_