#!/usr/bin/expect -f
set timeout 300

set UEFI "/opt/homebrew/share/qemu/edk2-x86_64-code.fd"
spawn qemu-system-x86_64 \
    -cdrom /Users/arnold/jarvis/os/debug/jarvis-rtos.iso \
    -m 256M -serial mon:stdio -nic none -boot order=d \
    -drive if=pflash,format=raw,readonly=on,file=$UEFI \
    -drive file=/Users/arnold/jarvis/os/build/fat32.img,format=raw,if=ide,index=1,media=disk \
    -no-reboot -no-shutdown

expect {
    -re {jarvis\$} {}
    -re {EXCEPTION|PANIC|FATAL} { puts "CRASH_DURING_BOOT"; exit 1 }
    timeout { puts "TIMEOUT_BOOT"; exit 2 }
}

send "selftest\n"

expect {
    -re {EXCEPTION|PANIC|FATAL} { puts "CRASH"; exit 1 }
    -re {Total:.*Passed:.*Failed:} { puts "OK"; exit 0 }
    timeout { puts "TIMEOUT"; exit 2 }
}
